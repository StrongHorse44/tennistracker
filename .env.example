# CourtTracker Environment Configuration

# Flask
FLASK_APP=backend.app
FLASK_ENV=development
SECRET_KEY=change-me-in-production

# Database
DATABASE_URL=sqlite:///courttracker.db
# For production PostgreSQL:
# DATABASE_URL=postgresql://user:password@localhost:5432/courttracker

# API Keys
API_TENNIS_KEY=your-api-tennis-key-here
SPORTRADAR_KEY=your-sportradar-key-here

# Scraping
SCRAPE_RATE_LIMIT_SECONDS=2.0
SCRAPE_MAX_RETRIES=3

# Redis (production only)
# REDIS_URL=redis://localhost:6379/0
